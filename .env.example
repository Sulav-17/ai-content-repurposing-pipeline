# Placeholder settings for local development.
# These values are not yet wired into the application.

APP_ENV=development
LOG_LEVEL=INFO
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
SECURITY_HEADERS_ENABLED=true
READINESS_REQUIRE_DATABASE=false
READINESS_REQUIRE_REDIS=false

# Optional local Ollama settings for POST /content/brief with provider="ollama".
# Ollama is not required for the default deterministic provider.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_TIMEOUT_SECONDS=60

# Optional PostgreSQL persistence settings for /generations endpoints.
# Use a local development password only; do not commit real secrets.
DATABASE_URL=postgresql+psycopg://postgres:change-me@localhost:5432/ai_content_pipeline

# Streamlit frontend settings.
API_BASE_URL=http://127.0.0.1:8000
API_TIMEOUT_SECONDS=30

# Local async media processing.
# Redis, FFmpeg, whisper.cpp, and the model are local dependencies.
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=media-processing
MEDIA_UPLOAD_DIR=.data/uploads
MEDIA_MAX_UPLOAD_MB=200
MEDIA_JOB_TIMEOUT_SECONDS=3600
MEDIA_JOB_RESULT_TTL_SECONDS=86400
MEDIA_JOB_FAILURE_TTL_SECONDS=86400
FFMPEG_EXECUTABLE=ffmpeg
WHISPER_CPP_EXECUTABLE=
WHISPER_CPP_MODEL_PATH=
WHISPER_CPP_THREADS=4
